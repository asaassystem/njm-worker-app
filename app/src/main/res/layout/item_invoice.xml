<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
      xmlns:android="http://schemas.android.com/apk/res/android"
      xmlns:app="http://schemas.android.com/apk/res-auto"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginHorizontal="8dp"
      android:layout_marginBottom="8dp"
      android:layoutDirection="rtl"
      app:cardCornerRadius="10dp"
      app:cardElevation="3dp"
      app:cardBackgroundColor="#FFFFFF">

      <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <!-- Top Row: Invoice Number + Status Badge -->
                <LinearLayout
                              android:layout_width="match_parent"
                              android:layout_height="wrap_content"
                              android:orientation="horizontal"
                              android:gravity="center_vertical"
                              android:layout_marginBottom="8dp">

                              <TextView
                                                android:id="@+id/tvInvoiceNumber"
                                                android:layout_width="0dp"
                                                android:layout_height="wrap_content"
                                                android:layout_weight="1"
                                                android:textColor="#0D1B3E"
                                                android:textSize="16sp"
                                                android:textStyle="bold"/>

                              <TextView
                                                android:id="@+id/tvInvoiceStatus"
                                                android:layout_width="wrap_content"
                                                android:layout_height="wrap_content"
                                                android:padding="6dp"
                                                android:textSize="12sp"
                                                android:textStyle="bold"/>
                </LinearLayout>

                <!-- Period -->
                <LinearLayout
                              android:layout_width="match_parent"
                              android:layout_height="wrap_content"
                              android:orientation="horizontal"
                              android:layout_marginBottom="4dp">

                              <TextView
                                                android:layout_width="wrap_content"
                                                android:layout_height="wrap_content"
                                                android:text="Period: "
                                                android:textColor="#888888"
                                                android:textSize="12sp"/>

                              <TextView
                                                android:id="@+id/tvInvoicePeriod"
                                                android:layout_width="0dp"
                                                android:layout_height="wrap_content"
                                                android:layout_weight="1"
                                                android:textColor="#555555"
                                                android:textSize="12sp"/>
                </LinearLayout>

                <!-- Washes count -->
                <LinearLayout
                              android:layout_width="match_parent"
                              android:layout_height="wrap_content"
                              android:orientation="horizontal"
                              android:layout_marginBottom="4dp">

                              <TextView
                                                android:layout_width="wrap_content"
                                                android:layout_height="wrap_content"
                                                android:text="Washes: "
                                                android:textColor="#888888"
                                                android:textSize="12sp"/>

                              <TextView
                                                android:id="@+id/tvInvoiceWashes"
                                                android:layout_width="0dp"
                                                android:layout_height="wrap_content"
                                                android:layout_weight="1"
                                                android:textColor="#555555"
                                                android:textSize="12sp"/>
                </LinearLayout>

                <!-- Separator -->
                <View
                              android:layout_width="match_parent"
                              android:layout_height="1dp"
                              android:background="#EEEEEE"
                              android:layout_marginVertical="8dp"/>

                <!-- Amounts Row -->
                <LinearLayout
                              android:layout_width="match_parent"
                              android:layout_height="wrap_content"
                              android:orientation="horizontal"
                              android:gravity="center_vertical">

                              <LinearLayout
                                                android:layout_width="0dp"
                                                android:layout_height="wrap_content"
                                                android:layout_weight="1"
                                                android:orientation="vertical">

                                                <TextView
                                                                      android:id="@+id/tvInvoiceTotal"
                                                                      android:layout_width="wrap_content"
                                                                      android:layout_height="wrap_content"
                                                                      android:textColor="#C9A227"
                                                                      android:textSize="18sp"
                                                                      android:textStyle="bold"/>

                                                <TextView
                                                                      android:id="@+id/tvInvoiceVat"
                                                                      android:layout_width="wrap_content"
                                                                      android:layout_height="wrap_content"
                                                                      android:textColor="#888888"
                                                                      android:textSize="11sp"/>
                              </LinearLayout>

                              <Button
                                                android:id="@+id/btnPrintInvoice"
                                                android:layout_width="wrap_content"
                                                android:layout_height="36dp"
                                                android:text="Print"
                                                android:textSize="12sp"
                                                android:backgroundTint="#0D1B3E"
                                                android:textColor="#C9A227"
                                                android:paddingStart="12dp"
                                                android:paddingEnd="12dp"/>
                </LinearLayout>

                <!-- Date -->
                <TextView
                              android:id="@+id/tvInvoiceDate"
                              android:layout_width="match_parent"
                              android:layout_height="wrap_content"
                              android:textColor="#AAAAAA"
                              android:textSize="10sp"
                              android:layout_marginTop="6dp"/>
      </LinearLayout>
</androidx.cardview.widget.CardView>
