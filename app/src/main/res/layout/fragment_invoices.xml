<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/njm_navy"
    android:padding="16dp">

    <!-- Create Invoice Section -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="إنشاء فاتورة ضريبية"
        android:textColor="@color/njm_gold"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnSelectStart"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="من تاريخ"
            android:backgroundTint="#333333"
            android:textColor="@android:color/white"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnSelectEnd"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="إلى تاريخ"
            android:backgroundTint="#333333"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvDateRange"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@android:color/white"
        android:padding="8dp"
        android:gravity="center" />

    <Button
        android:id="@+id/btnCreateInvoice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="إنشاء فاتورة جديدة"
        android:backgroundTint="@color/njm_gold"
        android:textColor="@color/njm_navy"
        android:textStyle="bold"
        android:layout_marginTop="8dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/njm_gold"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp" />

    <!-- Invoices List -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="الفواتير السابقة"
        android:textColor="@color/njm_gold"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <ProgressBar
        android:id="@+id/progressInvoices"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvNoInvoices"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="لا توجد فواتير"
        android:textColor="#888888"
        android:gravity="center"
        android:padding="16dp"
        android:visibility="gone" />

    <ListView
        android:id="@+id/lvInvoices"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
