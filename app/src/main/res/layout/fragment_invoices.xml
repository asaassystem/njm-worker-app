<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/njm_navy"
        android:layoutDirection="rtl">

        <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@color/njm_navy_card"
                    android:padding="14dp"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="2dp">
                    <ImageView android:layout_width="36dp" android:layout_height="36dp"
                                    android:src="@drawable/njm_logo" android:scaleType="fitCenter"
                                    android:contentDescription="NJM" android:layout_marginEnd="10dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                    android:layout_weight="1" android:orientation="vertical">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                                        android:text="Invoices" android:textColor="@color/njm_gold"
                                                        android:textSize="16sp" android:textStyle="bold"/>
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                                        android:text="ZATCA Tax Invoices" android:textColor="#AAAAAA" android:textSize="11sp"/>
                    </LinearLayout>
        </LinearLayout>

        <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/njm_navy_card"
                    android:padding="14dp"
                    android:layout_marginBottom="4dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                    android:orientation="horizontal" android:layout_marginBottom="8dp">
                                    <Button android:id="@+id/btnSelectStart" android:layout_width="0dp"
                                                        android:layout_height="40dp" android:layout_weight="1"
                                                        android:text="From Date" android:backgroundTint="#1E2D55"
                                                        android:textColor="@color/njm_gold" android:textSize="12sp"
                                                        android:layout_marginEnd="4dp"/>
                                    <Button android:id="@+id/btnSelectEnd" android:layout_width="0dp"
                                                        android:layout_height="40dp" android:layout_weight="1"
                                                        android:text="To Date" android:backgroundTint="#1E2D55"
                                                        android:textColor="@color/njm_gold" android:textSize="12sp"
                                                        android:layout_marginStart="4dp"/>
                    </LinearLayout>
                    <TextView android:id="@+id/tvDateRange" android:layout_width="match_parent"
                                    android:layout_height="wrap_content" android:textColor="@android:color/white"
                                    android:textSize="12sp" android:gravity="center" android:layout_marginBottom="10dp"/>
                    <Button android:id="@+id/btnCreateInvoice" android:layout_width="match_parent"
                                    android:layout_height="48dp" android:text="Create Invoice"
                                    android:backgroundTint="@color/njm_gold" android:textColor="@color/njm_navy"
                                    android:textStyle="bold" android:textSize="15sp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="12dp" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                    android:layout_weight="1" android:text="Previous Invoices"
                                    android:textColor="@color/njm_gold" android:textSize="14sp" android:textStyle="bold"/>
                    <ProgressBar android:id="@+id/progressInvoices" android:layout_width="24dp"
                                    android:layout_height="24dp" android:visibility="gone"
                                    android:indeterminateTint="@color/njm_gold"/>
        </LinearLayout>

        <TextView android:id="@+id/tvNoInvoices" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="No invoices yet"
                    android:textColor="#888888" android:gravity="center" android:padding="24dp"
                    android:visibility="gone"/>

        <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvInvoices"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:background="#F0F2F5"
                    android:padding="4dp"/>

</LinearLayout>
