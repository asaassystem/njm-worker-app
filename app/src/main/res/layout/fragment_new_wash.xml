<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/njm_navy"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Search Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ابحث عن السيارة"
            android:textColor="@color/njm_gold"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etPlateSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="رقم اللوحة..."
            android:background="@android:color/white"
            android:padding="12dp"
            android:textSize="18sp"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvSearchStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/njm_gold"
            android:padding="8dp"
            android:visibility="gone" />

        <ListView
            android:id="@+id/lvSearchResults"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@android:color/white"
            android:visibility="gone" />

        <!-- Car Info Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardCarInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="@color/njm_navy">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="اللوحة:"
                        android:textColor="@color/njm_gold"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvCarPlate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:textColor="@android:color/white"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="4dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="النوع:" android:textColor="@color/njm_gold" />
                    <TextView android:id="@+id/tvCarType" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:textColor="@android:color/white" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="4dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="المالك:" android:textColor="@color/njm_gold" />
                    <TextView android:id="@+id/tvCarOwner" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:textColor="@android:color/white" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="4dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="الهاتف:" android:textColor="@color/njm_gold" />
                    <TextView android:id="@+id/tvCarPhone" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:textColor="@android:color/white" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="4dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="السيارة:" android:textColor="@color/njm_gold" />
                    <TextView android:id="@+id/tvCarBrand" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:textColor="@android:color/white" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="4dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="الجهة:" android:textColor="@color/njm_gold" />
                    <TextView android:id="@+id/tvCarOrg" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:textColor="@android:color/white" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="سعر الغسيل:" android:textColor="@color/njm_gold" android:textStyle="bold" />
                    <TextView android:id="@+id/tvWashPrice" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:textColor="@color/njm_gold" android:textSize="20sp" android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Payment Toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="الدفع:"
                android:textColor="@android:color/white"
                android:textSize="16sp" />

            <Switch
                android:id="@+id/switchPaid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="مدفوع"
                android:textColor="@color/njm_gold" />

        </LinearLayout>

        <!-- Notes -->
        <EditText
            android:id="@+id/etWashNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="ملاحظات (اختياري)"
            android:background="@android:color/white"
            android:padding="12dp"
            android:layout_marginTop="12dp"
            android:minLines="2" />

        <!-- Buttons -->
        <ProgressBar
            android:id="@+id/progressWash"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnRecordWash"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="تسجيل الغسيل"
            android:backgroundTint="@color/njm_gold"
            android:textColor="@color/njm_navy"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginTop="12dp"
            android:enabled="false"
            android:alpha="0.5" />

        <Button
            android:id="@+id/btnPrintReceipt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="طباعة البيانات"
            android:backgroundTint="#333333"
            android:textColor="@android:color/white"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>
