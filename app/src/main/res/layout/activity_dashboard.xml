<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/njm_navy">

    <!-- Header with NJM Branding -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/njm_navy"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- NJM Logo Text (star symbol) -->
        <TextView
            android:id="@+id/ivLogo"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="★"
            android:textSize="28sp"
            android:textColor="@color/njm_gold"
            android:gravity="center"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvWorkerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="مغسلة نجم"
                android:textColor="@color/njm_gold"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NJM Car Wash"
                android:textColor="#AAAAAA"
                android:textSize="11sp" />

        </LinearLayout>

        <!-- Language Switcher -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginEnd="8dp">

            <Button
                android:id="@+id/btnLangAr"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="ع"
                android:textSize="12sp"
                android:backgroundTint="@color/njm_gold"
                android:textColor="@color/njm_navy"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />

            <Button
                android:id="@+id/btnLangEn"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="En"
                android:textSize="12sp"
                android:backgroundTint="#555555"
                android:textColor="@android:color/white"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginStart="4dp" />

            <Button
                android:id="@+id/btnLangBn"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="বা"
                android:textSize="12sp"
                android:backgroundTint="#555555"
                android:textColor="@android:color/white"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginStart="4dp" />

        </LinearLayout>

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="خروج"
            android:textSize="12sp"
            android:backgroundTint="#CC0000"
            android:textColor="@android:color/white"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <!-- Tab Layout -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/njm_navy"
        app:tabTextColor="#888888"
        app:tabSelectedTextColor="@color/njm_gold"
        app:tabIndicatorColor="@color/njm_gold"
        app:tabMode="scrollable" />

    <!-- ViewPager -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Developer Credit Footer -->
    <TextView
        android:id="@+id/tvDeveloper"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="meshari.tech"
        android:textColor="#666666"
        android:textSize="10sp"
        android:gravity="center"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:background="@color/njm_navy" />

</LinearLayout>
