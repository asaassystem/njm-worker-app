<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f1b35"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="40dp"
        android:paddingBottom="32dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <!-- Logo Card with Gold Border -->
        <LinearLayout
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:gravity="center"
            android:background="#1e2d50"
            android:layout_marginBottom="24dp">

            <!-- Logo loaded by Glide in PinLoginActivity -->
            <ImageView
                android:id="@+id/ivAppLogo"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@drawable/njm_logo"
                android:scaleType="fitCenter"
                android:contentDescription="NJM Logo" />
        </LinearLayout>

        <!-- App Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="نظام نجم"
            android:textColor="#c9a227"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NJM Car Wash System"
            android:textColor="#8899bb"
            android:textSize="13sp"
            android:layout_marginBottom="32dp" />

        <!-- PIN Display Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1a2744"
            android:padding="20dp"
            android:layout_marginBottom="24dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/enter_pin"
                android:textColor="#aabbcc"
                android:textSize="14sp"
                android:layout_marginBottom="16dp" />

            <!-- PIN Dots -->
            <LinearLayout
                android:id="@+id/pinDotsLayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/dot1"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="@string/pin_dot_empty"
                    android:textSize="32sp"
                    android:textColor="#c9a227"
                    android:gravity="center"
                    android:layout_margin="4dp" />
                <TextView
                    android:id="@+id/dot2"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="@string/pin_dot_empty"
                    android:textSize="32sp"
                    android:textColor="#c9a227"
                    android:gravity="center"
                    android:layout_margin="4dp" />
                <TextView
                    android:id="@+id/dot3"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="@string/pin_dot_empty"
                    android:textSize="32sp"
                    android:textColor="#c9a227"
                    android:gravity="center"
                    android:layout_margin="4dp" />
                <TextView
                    android:id="@+id/dot4"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="@string/pin_dot_empty"
                    android:textSize="32sp"
                    android:textColor="#c9a227"
                    android:gravity="center"
                    android:layout_margin="4dp" />
            </LinearLayout>

            <!-- Error Text -->
            <TextView
                android:id="@+id/tvError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#ff5252"
                android:textSize="13sp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Number Pad -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                <Button android:id="@+id/btn1" android:layout_width="85dp" android:layout_height="85dp" android:text="1" android:textSize="26sp" android:textColor="@android:color/white" android:backgroundTint="#1e2d50" android:layout_margin="5dp" />
                <Button android:id="@+id/btn2" android:layout_width="85dp" android:layout_height="85dp" android:text="2" android:textSize="26sp" android:textColor="@android:color/white" android:backgroundTint="#1e2d50" android:layout_margin="5dp" />
                <Button android:id="@+id/btn3" android:layout_width="85dp" android:layout_height="85dp" android:text="3" android:textSize="26sp" android:textColor="@android:color/white" android:backgroundTint="#1e2d50" android:layout_margin="5dp" />
            </LinearLayout>

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                <Button android:id="@+id/btn4" android:layout_width="85dp" android:layout_height="85dp" android:text="4" android:textSize="26sp" android:textColor="@android:color/white" android:backgroundTint="#1e2d50" android:layout_margin="5dp" />
                <Button android:id="@+id/btn5" android:layout_width="85dp" android:layout_height="85dp" android:text="5" android:textSize="26sp" android:textColor="@android:color/white" android:backgroundTint="#1e2d50" android:layout_margin="5dp" />
                <Button android:id="@+id/btn6" android:layout_width="85dp" android:layout_height="85dp" android:text="6" android:textSize="26sp" android:textColor="@android:color/white" android:backgroundTint="#1e2d50" android:layout_margin="5dp" />
            </LinearLayout>

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                <Button android:id="@+id/btn7" android:layout_width="85dp" android:layout_height="85dp" android:text="7" android:textSize="26sp" android:textColor="@android:color/white" android:backgroundTint="#1e2d50" android:layout_margin="5dp" />
                <Button android:id="@+id/btn8" android:layout_width="85dp" android:layout_height="85dp" android:text="8" android:textSize="26sp" android:textColor="@android:color/white" android:backgroundTint="#1e2d50" android:layout_margin="5dp" />
                <Button android:id="@+id/btn9" android:layout_width="85dp" android:layout_height="85dp" android:text="9" android:textSize="26sp" android:textColor="@android:color/white" android:backgroundTint="#1e2d50" android:layout_margin="5dp" />
            </LinearLayout>

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                <Button android:id="@+id/btnDelete" android:layout_width="85dp" android:layout_height="85dp" android:text="&#x232B;" android:textSize="22sp" android:textColor="#c9a227" android:backgroundTint="#1e2d50" android:layout_margin="5dp" />
                <Button android:id="@+id/btn0" android:layout_width="85dp" android:layout_height="85dp" android:text="0" android:textSize="26sp" android:textColor="@android:color/white" android:backgroundTint="#1e2d50" android:layout_margin="5dp" />
                <Button android:id="@+id/btnLogin" android:layout_width="85dp" android:layout_height="85dp" android:text="@string/login" android:textSize="14sp" android:textColor="#0f1b35" android:backgroundTint="#c9a227" android:layout_margin="5dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:indeterminateTint="#c9a227"
            android:visibility="gone" />

        <!-- Footer -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="meshari.tech"
            android:textColor="#445566"
            android:textSize="10sp"
            android:layout_marginTop="24dp" />

    </LinearLayout>
</ScrollView>
