<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".NjmApp"
        android:allowBackup="false"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.NjmWorker"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".ui.login.PinLoginActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.dashboard.DashboardActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.search.SearchActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <receiver
            android:name=".printer.PrinterStatusReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="woyou.aidlservice.jiuv5.NORMAL_ACTION" />
                <action android:name="woyou.aidlservice.jiuv5.OUT_OF_PAPER_ACTION" />
                <action android:name="woyou.aidlservice.jiuv5.OVER_HEATING_ACITON" />
                <action android:name="woyou.aidlservice.jiuv5.COVER_OPEN_ACTION" />
            </intent-filter>
        </receiver>

    </application>

</manifest>